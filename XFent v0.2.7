local function drawBox(obj,bPos,bSize,color)
    local bx=obj.box; local x,y,w,h=bPos.X,bPos.Y,bSize.X,bSize.Y; local cr=math.min(w,h)*Cfg.CornerRatio
    for _,l in pairs(bx) do l.Visible=false end
    local function set(l,fx,fy,tx,ty) l.From=Vector2.new(fx,fy); l.To=Vector2.new(tx,ty); l.Color=color; l.Thickness=Cfg.BoxThickness; l.Visible=true end
    if Cfg.BoxStyle=="Full" then set(bx.L1,x,y,x+w,y); set(bx.L2,x,y+h,x+w,y+h); set(bx.L3,x,y,x,y+h); set(bx.L4,x+w,y,x+w,y+h)
    else set(bx.L1,x,y,x+cr,y); set(bx.L2,x,y,x,y+cr); set(bx.L3,x+w,y,x+w-cr,y); set(bx.L4,x+w,y,x+w,y+cr); set(bx.L5,x,y+h,x+cr,y+h); set(bx.L6,x,y+h,x,y+h-cr); set(bx.L7,x+w,y+h,x+w-cr,y+h); set(bx.L8,x+w,y+h,x+w,y+h-cr) end
end

