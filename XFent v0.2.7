local function updateWorldESP()
    local char=LocalPlayer.Character; local lr=char and char:FindFirstChild("HumanoidRootPart")

    for _,e in ipairs(exitDrawDots) do e.draw.Visible=false; e.arrow.Visible=false end
    if Cfg.ShowExits and lr then
        for i,part in ipairs(exitParts) do
            ensureWorldLabel(exitDrawDots,i,EXIT_C)
            local dist=math.floor((part.Position-lr.Position).Magnitude)
            placeWorldLabel(exitDrawDots[i],part.Position+Vector3.new(0,3,0),string.format("Exit | %d st",dist),lr)
        end
    end

    if deathDrawDot then deathDrawDot.draw.Visible=false; deathDrawDot.arrow.Visible=false end
    if Cfg.ShowDeathMark and lastDeathPos and lr then
        if not deathDrawDot then
            local d=Drawing.new("Text"); d.Size=15; d.Center=true; d.Outline=true; d.Font=2; d.Color=DEATH_C; d.ZIndex=8; d.Visible=false
            local a=Drawing.new("Text"); a.Size=15; a.Center=true; a.Outline=true; a.Font=2; a.Color=DEATH_C; a.ZIndex=8; a.Visible=false
            deathDrawDot={draw=d,arrow=a}
        end
        local dist=math.floor((lastDeathPos-lr.Position).Magnitude)
        placeWorldLabel(deathDrawDot,lastDeathPos+Vector3.new(0,3,0),string.format("Death | %d st",dist),lr)
    end

    for _,e in ipairs(questDrawDots) do e.draw.Visible=false; e.arrow.Visible=false end
    if Cfg.ShowQuestItems and lr then
        for i,qi in ipairs(questItems) do
            local pos=qi.pos; pcall(function() if qi.obj and qi.obj.Parent then if qi.obj:IsA("BasePart") then pos=qi.obj.Position elseif qi.obj:IsA("Model") then local bp=qi.obj.PrimaryPart or qi.obj:FindFirstChildOfClass("BasePart"); if bp then pos=bp.Position end end end end)
            if pos then
                ensureWorldLabel(questDrawDots,i,QUEST_C)
                local dist=math.floor((pos-lr.Position).Magnitude)
                placeWorldLabel(questDrawDots[i],pos+Vector3.new(0,3,0),string.format("%s | %d st",qi.name,dist),lr)
            end
        end
    end

    for _,th in ipairs(teammateHUDs) do if th.nl then th.nl.Visible=false end; if th.hl then th.hl.Visible=false end end
    for _,th in ipairs(teammateHUDs) do
        local p=th.player; if p and p.Character then
            local root=p.Character:FindFirstChild("HumanoidRootPart"); local hum=p.Character:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health>0 then
                local sp,vis,dep=toScreen(root.Position+Vector3.new(0,4,0))
                if vis and dep>0 then
                    if not th.nl then th.nl=Drawing.new("Text"); th.nl.Size=14; th.nl.Center=true; th.nl.Outline=true; th.nl.Font=2; th.nl.Color=Color3.fromRGB(100,200,255); th.nl.ZIndex=7; th.hl=Drawing.new("Text"); th.hl.Size=12; th.hl.Center=true; th.hl.Outline=true; th.hl.Font=2; th.hl.ZIndex=7 end
                    local pct=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1); local wn=getWeaponName(p.Character)
                    th.nl.Position=sp; th.nl.Text=p.DisplayName..(wn and ("  ["..wn.."]") or ""); th.nl.Visible=true
                    th.hl.Position=Vector2.new(sp.X,sp.Y+18); th.hl.Text=string.format("HP %.0f%%",pct*100); th.hl.Color=Color3.fromRGB(math.floor(255*(1-pct)),math.floor(255*pct),50); th.hl.Visible=true
                end
            end
        end
    end

    if aimTraceLine then aimTraceLine.Visible=false end
    if Cfg.AimbotEnabled and Cfg.AimbotTraceLine then
        local target=getTarget()
        if target and target.Character then
            local part=target.Character:FindFirstChild(Cfg.AimbotPart) or target.Character:FindFirstChild("HumanoidRootPart")
            if part then
                if not aimTraceLine then aimTraceLine=Drawing.new("Line"); aimTraceLine.Thickness=1; aimTraceLine.ZIndex=9 end
                local vp=Camera.ViewportSize; local sp,on,dep=toScreen(part.Position)
                if on and dep>0 then aimTraceLine.From=Vector2.new(vp.X/2,vp.Y/2); aimTraceLine.To=sp; aimTraceLine.Color=Color3.fromRGB(255,60,60); aimTraceLine.Visible=true end
            end
        end
    end
end

