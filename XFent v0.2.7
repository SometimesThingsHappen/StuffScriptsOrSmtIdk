-- ============================================================
-- ESP UPDATE
-- ============================================================
local function updateESP(player)
    local obj=ESPObjects[player]; if not obj then return end
    local char=player.Character; if not char then hideAll(obj); return end
    local root=char:FindFirstChild("HumanoidRootPart"); if not root then hideAll(obj); return end
    local _,onScreen,depth=toScreen(root.Position); if not onScreen or depth<0 then hideAll(obj); return end
    local dist=(root.Position-Camera.CFrame.Position).Magnitude; if dist>Cfg.MaxDistance then hideAll(obj); return end
    local hum=char:FindFirstChildOfClass("Humanoid"); if not hum or hum.Health<=0 then hideAll(obj); return end
    if Cfg.TeamCheck and player.Team==LocalPlayer.Team then hideAll(obj); return end
    local color=getColor(player); local extents=char:GetExtentsSize(); local cf=root.CFrame
    local topSP,topVis=toScreen((cf*CFrame.new(0,extents.Y/2,0)).Position); local bottomSP,bottomVis=toScreen((cf*CFrame.new(0,-extents.Y/2,0)).Position)
    if not(topVis and bottomVis) then hideAll(obj); return end
    local height=math.abs(bottomSP.Y-topSP.Y); local width=height*0.55; local bPos=Vector2.new(topSP.X-width/2,topSP.Y); local centerX=topSP.X
    if Cfg.Box then drawBox(obj,bPos,Vector2.new(width,height),color) else for _,l in pairs(obj.box) do l.Visible=false end end
    if Cfg.Tracer then obj.tracer.From=tracerOrigin(); obj.tracer.To=Vector2.new(centerX,bPos.Y+height/2); obj.tracer.Color=color; obj.tracer.Thickness=Cfg.TracerThickness; obj.tracer.Visible=true else obj.tracer.Visible=false end
    if Cfg.HealthBar then
        local pct=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1); local bw=4; local bx2=bPos.X-bw-3
        obj.healthbar.BG.Position=Vector2.new(bx2-1,bPos.Y-1); obj.healthbar.BG.Size=Vector2.new(bw+2,height+2); obj.healthbar.BG.Transparency=0.4; obj.healthbar.BG.Visible=true
        local fh=math.max(height*pct,1); obj.healthbar.Fill.Position=Vector2.new(bx2,bPos.Y+height-fh); obj.healthbar.Fill.Size=Vector2.new(bw,fh); obj.healthbar.Fill.Color=Color3.fromRGB(math.floor(255*(1-pct)),math.floor(255*pct),0); obj.healthbar.Fill.Transparency=1; obj.healthbar.Fill.Visible=true
        if Cfg.HealthText then obj.healthbar.Text.Text=math.floor(hum.Health).."hp"; obj.healthbar.Text.Position=Vector2.new(bx2+bw/2,bPos.Y+height-fh-14); obj.healthbar.Text.Visible=true else obj.healthbar.Text.Visible=false end
    else for _,v in pairs(obj.healthbar) do v.Visible=false end end
    if Cfg.NameESP then obj.labels.Name.Text=player.DisplayName; obj.labels.Name.Position=Vector2.new(centerX,bPos.Y-16); obj.labels.Name.Color=color; obj.labels.Name.Size=Cfg.TextSize; obj.labels.Name.Visible=true else obj.labels.Name.Visible=false end
    local below=2
    if Cfg.DistanceESP then obj.labels.Distance.Text=string.format("[%.0f st]",dist); obj.labels.Distance.Position=Vector2.new(centerX,bPos.Y+height+below); obj.labels.Distance.Color=Color3.fromRGB(170,170,170); obj.labels.Distance.Size=Cfg.TextSize-1; obj.labels.Distance.Visible=true; below=below+14 else obj.labels.Distance.Visible=false end
    if Cfg.WeaponESP then local wn=getWeaponName(char); obj.labels.Weapon.Text=wn and ("[ "..wn.." ]") or "[ Unarmed ]"; obj.labels.Weapon.Position=Vector2.new(centerX,bPos.Y+height+below); obj.labels.Weapon.Color=wn and Color3.fromRGB(255,190,60) or Color3.fromRGB(120,120,120); obj.labels.Weapon.Size=Cfg.TextSize-2; obj.labels.Weapon.Visible=true else obj.labels.Weapon.Visible=false end
    drawSkeleton(obj,char)
    if Cfg.Chams then if obj.highlight.Parent~=char then obj.highlight.Parent=char end; obj.highlight.FillColor=Cfg.ChamsFill; obj.highlight.OutlineColor=Cfg.ChamsOutline; obj.highlight.FillTransparency=Cfg.ChamsFillTrans; obj.highlight.OutlineTransparency=Cfg.ChamsOutTrans; obj.highlight.Enabled=true else obj.highlight.Enabled=false end
end


