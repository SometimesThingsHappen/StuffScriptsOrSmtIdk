    local knob=Instance.new("Frame"); knob.Size=UDim2.new(0,10,0,10); knob.Position=UDim2.new(1,-5,0.5,-5); knob.BackgroundColor3=Color3.fromRGB(220,220,220); knob.BorderSizePixel=0; knob.ZIndex=6; knob.Parent=fill; Instance.new("UICorner",knob).CornerRadius=UDim.new(0.5,0)
    local dragging=false
    local function set(v) v=math.clamp(math.floor(v),min,max); local pct=(v-min)/(max-min); fill.Size=UDim2.new(pct,0,1,0); ltext.Text=lbl..":  "..v; onChange(v) end; set(default)
    local function fromX(x) local tp=track.AbsolutePosition; local ts=track.AbsoluteSize; set(min+math.clamp((x-tp.X)/ts.X,0,1)*(max-min)) end
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging=true; fromX(i.Position.X) end end)
