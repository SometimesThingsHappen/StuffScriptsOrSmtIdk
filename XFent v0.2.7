local function makeSlider(parent,lbl,min,max,default,onChange)
    local holder=Instance.new("Frame"); holder.Size=UDim2.new(1,0,0,46); holder.BackgroundColor3=GREY; holder.BackgroundTransparency=0.3; holder.BorderSizePixel=0; holder.ZIndex=3; holder.Parent=parent; Instance.new("UICorner",holder).CornerRadius=UDim.new(0,6)
