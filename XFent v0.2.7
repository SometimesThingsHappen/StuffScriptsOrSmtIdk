local function switchTab(page,btn,layout)
    pageESP.Visible=false; pageMap.Visible=false; pagePlayers.Visible=false; pageAimbot.Visible=false; pageSet.Visible=false
    page.Visible=true; activeTab=page; activeLayout=layout
    for _,b in pairs(tabBtns) do b.BackgroundColor3=Color3.fromRGB(22,22,22); b.TextColor3=Color3.fromRGB(100,100,100) end
    btn.BackgroundColor3=DARKRED; btn.TextColor3=Color3.fromRGB(215,215,215)
    local onESP=(page==pageESP); pinFrame.Visible=onESP; setPageBounds(pageESP,onESP)
    local onAim=(page==pageAimbot); aimPinFrame.Visible=onAim; setPageBounds(pageAimbot,onAim)
    if isOpen then panel.Size=UDim2.new(0,W,0,getOpenHeight()) end
end

