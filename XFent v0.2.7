-- WORLD LABEL HELPERS
-- ============================================================
local function ensureWorldLabel(tbl,i,col)
    if not tbl[i] then
        local d=Drawing.new("Text"); d.Size=15; d.Center=true; d.Outline=true; d.Font=2; d.Color=col; d.ZIndex=8; d.Visible=false
        local a=Drawing.new("Text"); a.Size=15; a.Center=true; a.Outline=true; a.Font=2; a.Color=col; a.ZIndex=8; a.Visible=false
        tbl[i]={draw=d,arrow=a}
    end
end
local function placeWorldLabel(entry,worldPos,txt,lr)
    local vp=Camera.ViewportSize
    local sp,on,dep=toScreen(worldPos)
    if on and dep>0 then
        entry.draw.Position=sp; entry.draw.Text=txt; entry.draw.Visible=true; entry.arrow.Visible=false
    else

        local cx,cy=vp.X/2,vp.Y/2; local dx,dy=sp.X-cx,sp.Y-cy
        if dep<0 then dx=-dx; dy=-dy end
        local pad=30; local sx=(math.abs(dx)>(vp.X/2-pad)) and (vp.X/2-pad)/math.abs(dx) or 1; local sy=(math.abs(dy)>(vp.Y/2-pad)) and (vp.Y/2-pad)/math.abs(dy) or 1; local s=math.min(sx,sy)
        local ex,ey=cx+dx*s,cy+dy*s

        local ang=math.deg(math.atan2(dy,dx))
        local arrows={"->","->","v","<-","<-","<-","^","->"}
        local idx=math.floor(((ang+202.5)%360)/45)+1
        local sym=arrows[idx] or "->"
        entry.arrow.Position=Vector2.new(ex,ey); entry.arrow.Text=sym.." "..txt; entry.arrow.Visible=true; entry.draw.Visible=false
    end
end


