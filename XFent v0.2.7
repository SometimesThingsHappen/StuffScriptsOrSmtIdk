-- ============================================================
-- HIDE ALL ESP
-- ============================================================
local function hideAll(obj)
    if not obj then return end
    for _,v in pairs(obj.box) do v.Visible=false end; obj.tracer.Visible=false
    for _,v in pairs(obj.healthbar) do v.Visible=false end
    for _,v in pairs(obj.labels) do v.Visible=false end
    for _,v in pairs(obj.skeleton) do v.Visible=false end
    obj.highlight.Enabled=false
end

-- ============================================================
-- REMOVE ESP
-- ============================================================
local function removeESP(player)
    local obj=ESPObjects[player]; if not obj then return end
    for _,v in pairs(obj.box) do v:Remove() end; obj.tracer:Remove()
    for _,v in pairs(obj.healthbar) do v:Remove() end
    for _,v in pairs(obj.labels) do v:Remove() end
    for _,v in pairs(obj.skeleton) do v:Remove() end
    obj.highlight:Destroy(); ESPObjects[player]=nil
end

