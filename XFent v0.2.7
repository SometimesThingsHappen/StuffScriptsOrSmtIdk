-- ============================================================
-- RENDER LOOP
-- ============================================================
RunService.RenderStepped:Connect(function(dt)
    if Unloaded then return end
    local now=tick()
    table.insert(fpsBuffer,dt); if #fpsBuffer>20 then table.remove(fpsBuffer,1) end
    local avg=0; for _,v in ipairs(fpsBuffer) do avg=avg+v end; FPS=math.floor(1/(avg/#fpsBuffer))

    local interval=1/math.max(Cfg.RefreshRate,1)
    if now-lastRender>=interval then
        lastRender=now
        if not Cfg.Enabled then for _,p in ipairs(Players:GetPlayers()) do hideAll(ESPObjects[p]) end
        else for _,p in ipairs(Players:GetPlayers()) do if p~=LocalPlayer then if not ESPObjects[p] then createESP(p) end; updateESP(p) end end end
        updateRadar()
    end

    updateWorldESP()

    if Cfg.AimbotFOVCircle then ensureFOV(); local vp=Camera.ViewportSize; fovCircle.Position=Vector2.new(vp.X/2,vp.Y/2); fovCircle.Radius=Cfg.AimbotFOV; fovCircle.Visible=true
    elseif fovCircle then fovCircle.Visible=false end

    if Cfg.AimbotEnabled then
        local isHeld=(Cfg.AimbotMouse and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)) or (Cfg.AimbotKey and UserInputService:IsKeyDown(Cfg.AimbotKey)) or false
        if isHeld then local target=getTarget(); if target and target.Character then local part=target.Character:FindFirstChild(Cfg.AimbotPart) or target.Character:FindFirstChild("HumanoidRootPart"); if part then local sf=math.clamp(Cfg.AimbotSmooth/10,0.05,1); Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,part.Position),sf) end end end
    end

    local char=LocalPlayer.Character; local hum=char and char:FindFirstChildOfClass("Humanoid")
    local hpPct=hum and math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1) or 1
    local curHP=hum and hum.Health or 100
    if curHP<lastHP-0.5 then
        local dmg=lastHP-curHP; spawnDmgNumber(dmg)
        hudStroke.Thickness=7; hudStroke.Color=Color3.fromRGB(255,30,30)
        TweenService:Create(hudStroke,TweenInfo.new(1.0,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Thickness=1.2}):Play()
        for _,bar in ipairs(waveBars) do bar.BackgroundTransparency=0.3 end
        task.delay(1.0,function() end)
        if hpPct<=0.3 then showPopup() end
    end
    lastHP=curHP

    local waveSpeed,waveHeight,waveTransp,heartVol
    if hpPct>0.8 then waveSpeed=0.03; waveHeight=0.18; waveTransp=0.90; heartVol=0
    elseif hpPct>0.5 then waveSpeed=0.06; waveHeight=0.35; waveTransp=0.84; heartVol=0
    elseif hpPct>0.35 then waveSpeed=0.13; waveHeight=0.55; waveTransp=0.78; heartVol=0.1
    else waveSpeed=0.24; waveHeight=0.88; waveTransp=0.70; heartVol=0.4 end
    waveTime=waveTime+waveSpeed
    for i,bar in ipairs(waveBars) do
        local phase=waveTime+i*0.4
        local h= hpPct<=0.35 and (math.abs(math.sin(phase))*0.6+math.abs(math.sin(phase*2.3))*0.4)*waveHeight+0.04 or math.abs(math.sin(phase))*waveHeight+0.04
        bar.Size=UDim2.new(1/WAVE_BARS,0,h,0); bar.Position=UDim2.new((i-1)/WAVE_BARS,0,1-h,0); bar.BackgroundTransparency=waveTransp
    end

    if hpPct>0.5 then

    elseif hpPct>0.35 then
        local pulse=math.abs(math.sin(now*2.5)); hudStroke.Color=Color3.fromRGB(255,math.floor(140+pulse*80),0); hudStroke.Thickness=1.2+pulse*1.2
    else
        local pulse=math.abs(math.sin(now*7)); hudStroke.Color=Color3.fromRGB(255,math.floor(pulse*30),math.floor(pulse*10)); hudStroke.Thickness=1.4+pulse*3
    end
    heartbeatSound.Volume=heartVol

    if Cfg.ShowHUD and hudAnimDone and now-lastHUDUpdate>=0.1 then
        lastHUDUpdate=now
        local root=char and char:FindFirstChild("HumanoidRootPart")
        if root then local pos=root.Position; hudX.Text=string.format("X  %.1f",pos.X); hudY.Text=string.format("Y  %.1f",pos.Y); hudZ.Text=string.format("Z  %.1f",pos.Z) end
        hudHPFill.Size=UDim2.new(hpPct,0,1,0); hudHPFill.BackgroundColor3=Color3.fromRGB(math.floor(255*(1-hpPct)),math.floor(255*hpPct),50)
        for i=1,MAX_TEAMMATES do
            local th=teammateHUDs[i]; local tc=tmCards[i]
            if th and tc then local p=th.player; if p and p.Character then local phum=p.Character:FindFirstChildOfClass("Humanoid"); if phum and phum.Health>0 then tc.card.Visible=true; tc.thumb.Image="rbxthumb://type=AvatarHeadShot&id="..p.UserId.."&w=48&h=48"; tc.name.Text=p.DisplayName; local ppct=math.clamp(phum.Health/math.max(phum.MaxHealth,1),0,1); tc.hpFill.Size=UDim2.new(ppct,0,1,0); tc.hpFill.BackgroundColor3=Color3.fromRGB(math.floor(255*(1-ppct)),math.floor(255*ppct),50); local pwn=getWeaponName(p.Character); tc.weapon.Text=pwn or ""; tc.weapon.TextColor3=pwn and Color3.fromRGB(255,190,60) or Color3.fromRGB(80,80,80) else tc.card.Visible=false end else tc.card.Visible=false end
            elseif tc then tc.card.Visible=false end
        end
    end

    if now-lastMapUpdate>=0.1 then
        lastMapUpdate=now
        local lr=char and char:FindFirstChild("HumanoidRootPart")
        if lr then
            local camLook=Camera.CFrame.LookVector; local camAngle=math.deg(math.atan2(camLook.X,camLook.Z))
            local dirs={{"N",0},{"E",90},{"S",180},{"W",270}}; local cl,cd="N",999
            for _,d in ipairs(dirs) do local diff=((d[2]-camAngle)%360); if diff>180 then diff=diff-360 end; if math.abs(diff)<cd then cd=math.abs(diff); cl=d[1] end end
            compassLbl.Text="Facing "..cl.."  "..string.format("%.0f",camAngle).."deg"
            local half=MAP_SIZE/2-10
            local angle=0; if Cfg.RadarRotate then angle=-math.atan2(Camera.CFrame.LookVector.Z,Camera.CFrame.LookVector.X)+math.pi/2 end
            local function worldToMapRot(pos)
                local rel=pos-lr.Position
                local rx=rel.X*math.cos(angle)-rel.Z*math.sin(angle); local rz=rel.X*math.sin(angle)+rel.Z*math.cos(angle)
                local mx=rx*(half/MAP_RANGE); local mz=rz*(half/MAP_RANGE)
                local d2=math.sqrt(mx*mx+mz*mz)
                if d2>half then mx=mx/d2*half; mz=mz/d2*half end
                return mx,mz
            end

            if Cfg.ShowExits then
                for i,part in ipairs(exitParts) do
                    if not mapExitDots[i] then
                        local f,l=makeMapDot(EXIT_C,"Exit",6); mapExitDots[i]={dot=f,lbl=l}
                    end
                    local mx,mz=worldToMapRot(part.Position)
                    mapExitDots[i].dot.Position=UDim2.new(0.5,mx-5,0.5,mz-5); mapExitDots[i].dot.Visible=true
                    local dist=math.floor((part.Position-lr.Position).Magnitude); mapExitDots[i].lbl.Text=string.format("Exit\n%dst",dist)
                end
                for i=#exitParts+1,#mapExitDots do mapExitDots[i].dot.Visible=false end
            else for _,e in ipairs(mapExitDots) do e.dot.Visible=false end end

            if Cfg.ShowDeathMark and lastDeathPos then
                if not mapDeathDot then local f,l=makeMapDot(DEATH_C,"Death",7); mapDeathDot={dot=f,lbl=l} end
                local mx,mz=worldToMapRot(lastDeathPos); mapDeathDot.dot.Position=UDim2.new(0.5,mx-5,0.5,mz-5); mapDeathDot.dot.Visible=true
                local dist=math.floor((lastDeathPos-lr.Position).Magnitude); mapDeathDot.lbl.Text=string.format("Death\n%dst",dist)
            elseif mapDeathDot then mapDeathDot.dot.Visible=false end

            if Cfg.ShowQuestItems then
                for i,qi in ipairs(questItems) do
                    local pos=qi.pos; pcall(function() if qi.obj and qi.obj.Parent then if qi.obj:IsA("BasePart") then pos=qi.obj.Position elseif qi.obj:IsA("Model") then local bp=qi.obj.PrimaryPart or qi.obj:FindFirstChildOfClass("BasePart"); if bp then pos=bp.Position end end end end)
                    if pos then
                        if not mapQuestDots[i] then local f,l=makeMapDot(QUEST_C,qi.name,6); mapQuestDots[i]={dot=f,lbl=l} end
                        local mx,mz=worldToMapRot(pos); mapQuestDots[i].dot.Position=UDim2.new(0.5,mx-5,0.5,mz-5); mapQuestDots[i].dot.Visible=true
                        local dist=math.floor((pos-lr.Position).Magnitude); mapQuestDots[i].lbl.Text=string.format("%s\n%dst",qi.name,dist)
                    end
                end
                for i=#questItems+1,#mapQuestDots do mapQuestDots[i].dot.Visible=false end
            else for _,e in ipairs(mapQuestDots) do e.dot.Visible=false end end
        end
    end

    if Cfg.ShowSysBar and now-lastSysUpdate>=0.5 then
        lastSysUpdate=now
        local fpsColor=FPS>=55 and Color3.fromRGB(100,220,100) or FPS>=30 and Color3.fromRGB(255,200,50) or Color3.fromRGB(255,80,80)
        sysFPS.Text=string.format("FPS  %d",FPS); sysFPS.TextColor3=fpsColor
        local t=os.date("*t"); local h=t.hour
        sysGreet.Text=h>=5 and h<12 and "Good Morning" or h>=12 and h<17 and "Good Afternoon" or h>=17 and h<21 and "Good Evening" or "Good Night"
        sysTime.Text=string.format("%02d:%02d:%02d",h,t.min,t.sec); sysDate.Text=string.format("%02d/%02d/%04d",t.month,t.day,t.year)
        sysPlayers.Text=string.format("👥 %d",#Players:GetPlayers())
    end
end)
