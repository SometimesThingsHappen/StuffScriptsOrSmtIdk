    if popupActive or not Cfg.Popups then return end; popupActive=true
    popupCard.Visible=true
    popupCard.BackgroundTransparency=0.15; popupLbl.TextTransparency=0; popupStroke.Transparency=0
    popupSound:Play()
    task.spawn(function()
        for _=1,4 do
            TweenService:Create(popupStroke,TweenInfo.new(0.18),{Color=Color3.fromRGB(255,255,100)}):Play()
            task.wait(0.2)
            TweenService:Create(popupStroke,TweenInfo.new(0.18),{Color=Color3.fromRGB(220,40,40)}):Play()
            task.wait(0.2)
        end
        task.wait(1.2)
        local fadeInfo=TweenInfo.new(0.4)
        TweenService:Create(popupCard,fadeInfo,{BackgroundTransparency=1}):Play()
        TweenService:Create(popupLbl,fadeInfo,{TextTransparency=1}):Play()
        TweenService:Create(popupStroke,fadeInfo,{Transparency=1}):Play()
        task.wait(0.45)
        popupCard.Visible=false
        popupLbl.TextTransparency=0
        popupStroke.Transparency=0
        popupActive=false
    end)
end


