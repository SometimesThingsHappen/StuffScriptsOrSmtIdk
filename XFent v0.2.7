-- MINI HUD VIEWPORT  (character preview)
-- ============================================================
task.spawn(function()
    task.wait(1.2)
    local function setupVP(char)

        for _,c in ipairs(vpFrame:GetChildren()) do if c:IsA("Model") then c:Destroy() end end
        pcall(function()
            char.Archivable=true; local clone=char:Clone(); char.Archivable=false

            for _,d in ipairs(clone:GetDescendants()) do
                if d:IsA("Script") or d:IsA("LocalScript") then d:Destroy() end
                if d:IsA("Humanoid") then d.DisplayDistanceType=Enum.HumanoidDisplayDistanceType.None end
            end
            clone.Parent=vpFrame
            local cr=clone:FindFirstChild("HumanoidRootPart")
            if cr then
                cr.Anchored=true
                cr.CFrame=CFrame.new(0,0,0)
                -- Camera sits BEHIND character (negative Z) looking toward positive Z = sees front face
                vpCam.CFrame=CFrame.new(Vector3.new(0,2.5,-8),Vector3.new(0,2.5,0))
            end

            RunService.Heartbeat:Connect(function()
                if Unloaded then return end
                local lc=LocalPlayer.Character; if not lc then return end
                local lr=lc:FindFirstChild("HumanoidRootPart"); if not lr then return end
                pcall(function()
                    if not cr or not cr.Parent then return end
                    for _,part in ipairs(lc:GetDescendants()) do
                        if part:IsA("BasePart") and part.Name~="HumanoidRootPart" then
                            local cp=clone:FindFirstChild(part.Name,true)
                            if cp and cp:IsA("BasePart") then
                                local rel=lr.CFrame:Inverse()*part.CFrame
                                cp.CFrame=cr.CFrame*rel
                            end
                        end
                    end
                end)
            end)
        end)
    end
    if LocalPlayer.Character then setupVP(LocalPlayer.Character) end
    LocalPlayer.CharacterAdded:Connect(function(char) task.wait(1); setupVP(char) end)
end)


