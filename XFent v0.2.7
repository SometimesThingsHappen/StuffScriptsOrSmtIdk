local function tracerOrigin()
    local vp=Camera.ViewportSize
    if Cfg.TracerOrigin=="Bottom" then return Vector2.new(vp.X/2,vp.Y)
    elseif Cfg.TracerOrigin=="Top" then return Vector2.new(vp.X/2,0)
    elseif Cfg.TracerOrigin=="Mouse" then return UserInputService:GetMouseLocation() end
    return Vector2.new(vp.X/2,vp.Y/2)
end

