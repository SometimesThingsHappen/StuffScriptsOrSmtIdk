local function buildPlayersPage()
    local listFrame=Instance.new("Frame"); listFrame.Size=UDim2.new(1,0,0,0); listFrame.BackgroundTransparency=1; listFrame.BorderSizePixel=0; listFrame.ZIndex=3; listFrame.AutomaticSize=Enum.AutomaticSize.Y; listFrame.Parent=pagePlayers
    local ll=Instance.new("UIListLayout"); ll.Padding=UDim.new(0,4); ll.HorizontalAlignment=Enum.HorizontalAlignment.Center; ll.Parent=listFrame
    local function isTeammate(p) for _,th in ipairs(teammateHUDs) do if th.player==p then return true end end; return false end
    local function refresh()
        for _,c in ipairs(listFrame:GetChildren()) do if not c:IsA("UIListLayout") then c:Destroy() end end
        local localRoot=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        for _,p in ipairs(Players:GetPlayers()) do
            local card=Instance.new("Frame"); card.Size=UDim2.new(1,0,0,54); card.BackgroundColor3=GREY; card.BackgroundTransparency=0.3; card.BorderSizePixel=0; card.ZIndex=3; card.Parent=listFrame; Instance.new("UICorner",card).CornerRadius=UDim.new(0,6)
            local thumb=Instance.new("ImageLabel"); thumb.Size=UDim2.new(0,36,0,36); thumb.Position=UDim2.new(0,8,0.5,-18); thumb.BackgroundColor3=Color3.fromRGB(25,25,25); thumb.BorderSizePixel=0; thumb.ZIndex=4; thumb.Image="rbxthumb://type=AvatarHeadShot&id="..p.UserId.."&w=48&h=48"; thumb.Parent=card; Instance.new("UICorner",thumb).CornerRadius=UDim.new(0.5,0)
            local nameL=Instance.new("TextLabel"); nameL.Size=UDim2.new(1,-90,0,16); nameL.Position=UDim2.new(0,50,0,6); nameL.BackgroundTransparency=1; nameL.Text=p.DisplayName..(p==LocalPlayer and "  (you)" or ""); nameL.TextColor3=p==LocalPlayer and Color3.fromRGB(255,190,60) or Color3.fromRGB(200,200,200); nameL.TextSize=11; nameL.Font=Enum.Font.GothamBold; nameL.TextXAlignment=Enum.TextXAlignment.Left; nameL.ZIndex=4; nameL.Parent=card
            local char=p.Character; local hum=char and char:FindFirstChildOfClass("Humanoid"); local root=char and char:FindFirstChild("HumanoidRootPart")
            local hp=hum and math.floor(hum.Health) or 0; local maxhp=hum and math.floor(hum.MaxHealth) or 100; local pct=math.clamp(hp/math.max(maxhp,1),0,1)
            local hpL=Instance.new("TextLabel"); hpL.Size=UDim2.new(1,-90,0,14); hpL.Position=UDim2.new(0,50,0,22); hpL.BackgroundTransparency=1; hpL.Text=string.format("HP  %d / %d",hp,maxhp); hpL.TextColor3=Color3.fromRGB(math.floor(255*(1-pct)),math.floor(255*pct),50); hpL.TextSize=10; hpL.Font=Enum.Font.GothamMedium; hpL.TextXAlignment=Enum.TextXAlignment.Left; hpL.ZIndex=4; hpL.Parent=card
            local dist="--"; if localRoot and root and p~=LocalPlayer then dist=string.format("%.0f st",(root.Position-localRoot.Position).Magnitude) end
            local distL=Instance.new("TextLabel"); distL.Size=UDim2.new(1,-90,0,14); distL.Position=UDim2.new(0,50,0,36); distL.BackgroundTransparency=1; distL.Text=dist; distL.TextColor3=Color3.fromRGB(120,120,120); distL.TextSize=9; distL.Font=Enum.Font.GothamMedium; distL.TextXAlignment=Enum.TextXAlignment.Left; distL.ZIndex=4; distL.Parent=card
            if p~=LocalPlayer then
                local pinBtn=Instance.new("TextButton"); pinBtn.Size=UDim2.new(0,28,0,22); pinBtn.Position=UDim2.new(1,-32,0.5,-11); pinBtn.BorderSizePixel=0; pinBtn.TextSize=14; pinBtn.Font=Enum.Font.GothamBold; pinBtn.ZIndex=5; pinBtn.AutoButtonColor=false; pinBtn.Parent=card; Instance.new("UICorner",pinBtn).CornerRadius=UDim.new(0,5)
                local function upPin() if isTeammate(p) then pinBtn.Text="-"; pinBtn.BackgroundColor3=Color3.fromRGB(80,20,20); pinBtn.TextColor3=Color3.fromRGB(255,100,100) else pinBtn.Text="+"; pinBtn.BackgroundColor3=Color3.fromRGB(20,60,20); pinBtn.TextColor3=Color3.fromRGB(100,220,100) end end; upPin()
                pinBtn.MouseButton1Click:Connect(function()
                    if isTeammate(p) then for i,th in ipairs(teammateHUDs) do if th.player==p then if th.nl then pcall(function() th.nl:Remove() end) end; if th.hl then pcall(function() th.hl:Remove() end) end; table.remove(teammateHUDs,i); break end end
                    elseif #teammateHUDs<MAX_TEAMMATES then table.insert(teammateHUDs,{player=p,nl=nil,hl=nil}) end; upPin()
                end)
            end
        end
    end
    refresh(); task.spawn(function() while not Unloaded do task.wait(2); pcall(refresh) end end)
end
